// 方案一流程图
digraph {
	graph [bgcolor=white fontname="Microsoft YaHei" fontsize=12 rankdir=LR size="12,6"]
	node [fillcolor=lightgray fontname="Microsoft YaHei" fontsize=9 shape=box style=filled]
	edge [fontname="Microsoft YaHei" fontsize=8]
	label="方案一流程图" labelloc=t
	"开始" [label="开始：用户将垃圾投入垃圾桶顶部的投放口"]
	"垃圾暂存" [label="垃圾暂存：垃圾落在垃圾暂存板上"]
	"图像采集" [label="图像采集：双目摄像头对暂存板上的垃圾进行图像采集"]
	"图像识别" [label="图像识别：采集到的图像信号发送至
Jetson Nano上位机进行垃圾类型识别"]
	"控制信号发送" [label="控制信号发送：上位机根据识别结果
向控制下位机发送控制信号"]
	"机械平台移动" [label="机械平台移动：下位机驱动两轴机械平台移动到指定位置"]
	"垃圾抓取" [label="垃圾抓取：步进电机控制机械爪的开合，抓取暂存板上的垃圾"]
	"垃圾投放" [label="垃圾投放：机械爪将抓取的垃圾投放到对应的垃圾桶中"]
	"垃圾压缩" [label="垃圾压缩：可回收垃圾经压缩装置压缩后滑落至垃圾桶"]
	"垃圾观察" [label="垃圾观察：通过透明箱体观察垃圾桶内垃圾是否装满"]
	"垃圾清理" [label="垃圾清理：垃圾桶装满后，抽取垃圾桶倒出垃圾"]
	"结束1" [label="结束：完成垃圾处理流程"]
	"开始" -> "垃圾暂存"
	"垃圾暂存" -> "图像采集"
	"图像采集" -> "图像识别"
	"图像识别" -> "控制信号发送"
	"控制信号发送" -> "机械平台移动"
	"机械平台移动" -> "垃圾抓取"
	"垃圾抓取" -> "垃圾投放"
	"垃圾投放" -> "垃圾压缩"
	"垃圾压缩" -> "垃圾观察"
	"垃圾观察" -> "垃圾清理"
	"垃圾清理" -> "结束1"
}
